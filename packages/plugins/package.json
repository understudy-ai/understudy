{
	"name": "@understudy/plugins",
	"version": "0.1.0",
	"private": true,
	"description": "Understudy plugin registry and loader",
	"type": "module",
	"main": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.js"
		}
	},
	"scripts": {
		"build": "tsc -p tsconfig.build.json",
		"typecheck": "tsc --noEmit",
		"clean": "rm -rf dist",
		"test": "vitest --run --config ../../vitest.package.config.ts"
	},
	"dependencies": {
		"@understudy/channels": "workspace:*",
		"@understudy/tools": "workspace:*",
		"@understudy/types": "workspace:*",
		"@mariozechner/pi-agent-core": "^0.56.2",
		"commander": "^13.1.0"
	},
	"devDependencies": {
		"@types/node": "^24.3.0",
		"typescript": "^5.7.3",
		"vitest": "^3.2.4"
	},
	"license": "MIT"
}
