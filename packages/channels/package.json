{
	"name": "@understudy/channels",
	"version": "0.2.0",
	"private": true,
	"description": "Understudy channel adapters (Web, Telegram, Discord, Slack, Signal, LINE, WhatsApp, iMessage)",
	"type": "module",
	"main": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.js"
		}
	},
	"scripts": {
		"build": "tsc -p tsconfig.build.json",
		"typecheck": "tsc --noEmit",
		"clean": "rm -rf dist",
		"test": "vitest --run --config ../../vitest.package.config.ts"
	},
	"dependencies": {
		"@understudy/core": "workspace:*",
		"@understudy/types": "workspace:*",
		"ws": "^8.18.0"
	},
	"optionalDependencies": {
		"grammy": "^1.35.0",
		"@slack/bolt": "^4.3.0",
		"discord.js": "^14.18.0",
		"@whiskeysockets/baileys": "7.0.0-rc.9",
		"qrcode-terminal": "^0.12.0"
	},
	"devDependencies": {
		"@types/ws": "^8.18.0",
		"@types/qrcode-terminal": "^0.12.2",
		"@types/node": "^24.3.0",
		"typescript": "^5.7.3",
		"vitest": "^3.2.4"
	},
	"license": "MIT"
}
