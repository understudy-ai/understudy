{
	"name": "@understudy/gateway",
	"version": "0.1.5",
	"private": true,
	"description": "Understudy gateway server (HTTP + WebSocket, message routing, pairing)",
	"type": "module",
	"main": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.js"
		}
	},
	"scripts": {
		"build": "tsc -p tsconfig.build.json",
		"typecheck": "tsc --noEmit",
		"clean": "rm -rf dist",
		"test": "vitest --run --config ../../vitest.package.config.ts"
	},
	"dependencies": {
		"@mariozechner/pi-agent-core": "^0.56.2",
		"@understudy/core": "workspace:*",
		"@understudy/types": "workspace:*",
		"@understudy/channels": "workspace:*",
		"@understudy/gui": "workspace:*",
		"@understudy/tools": "workspace:*",
		"ws": "^8.18.0",
		"express": "^5.1.0"
	},
	"devDependencies": {
		"@types/express": "^5.0.0",
		"@types/ws": "^8.18.0",
		"@types/node": "^24.3.0",
		"typescript": "^5.7.3",
		"vitest": "^3.2.4"
	},
	"license": "MIT"
}
